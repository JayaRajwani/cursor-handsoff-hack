# PayPal integration — copy to .env.local and fill in real values.
# Generate .env.local automatically with: npm run setup:paypal
# Never commit .env.local or real credentials.

PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id
PAYPAL_CLIENT_SECRET=your_paypal_sandbox_client_secret
PAYPAL_MODE=sandbox
PAYPAL_BUSINESS_EMAIL=your_sandbox_business_email
PAYPAL_SANDBOX_BUYER_EMAIL=your_sandbox_personal_buyer_email
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
PAYPAL_RETURN_URL=http://localhost:3000/payments/paypal/success
PAYPAL_CANCEL_URL=http://localhost:3000/payments/paypal/cancel

# Wassist — WhatsApp provider used by the Community Agent.
# Get a key at wassist.app → Settings → API Keys. Verified header is X-API-Key.
WASSIST_API_KEY=your_wassist_api_key
WASSIST_BASE_URL=https://backend.wassist.app/api/v1
WASSIST_TEST_RECIPIENT=+440000000000

# WhatsApp Business Cloud API (Meta Graph API) — alternative provider path.
# Mock mode is the default; these are only read when WHATSAPP_MODE=live.
# Create an app + WhatsApp product at https://developers.facebook.com and a
# System User token with whatsapp_business_messaging + whatsapp_business_management.
WHATSAPP_MODE=mock
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id
WHATSAPP_ACCESS_TOKEN=your_long_lived_system_user_token
WHATSAPP_APP_SECRET=your_meta_app_secret
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_DEFAULT_COUNTRY_CODE=+44
WHATSAPP_API_VERSION=v21.0
WHATSAPP_TEMPLATE_LANGUAGE=en_GB
# Optional — if routing via a BSP instead of Meta directly (Twilio / 360dialog):
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
